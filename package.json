{
  "name": "employee_dashboard",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/sinon": "^21.0.1",
    "cds-plugin-ui5": "^0.13.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "sinon": "^21.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4",
    "typescript": "^5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-employeedashboard": "cds watch --open employeedashboard/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-learningsmaster": "cds watch --open learningsmaster/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-projectsmaster": "cds watch --open projectsmaster/index.html?sap-ui-xx-viewCache=false --livereload false",
    "test": "mocha",
    "test:unit": "mocha 'test/unit/**/*.test.ts'",
    "test:integration": "cds d && mocha test/integration/**/*.test.ts --timeout 20000 --exit --reporter spec"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "auth": {
        "kind": "mocked",
        "users": {
          "Rajarajan": {
            "roles": [
              "HR_Admin",
              "Learning_Manager",
              "Project_Manager"
            ]
          },
          "TEST_USER_AUDIT": {
            "roles": [
              "HR_Audit"
            ]
          },
          "TEST_USER_LM": {
            "roles": [
              "Learning_Manager"
            ]
          },
          "TEST_USER_PM": {
            "roles": [
              "Project_Manager"
            ]
          }
        }
      }
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/employeedashboard",
    "app/learningsmaster",
    "app/projectsmaster"
  ]
}